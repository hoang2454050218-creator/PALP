# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_SETTINGS_MODULE=palp.settings.development
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
POSTGRES_DB=palp
POSTGRES_USER=palp
POSTGRES_PASSWORD=palp_dev_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
DB_CONN_MAX_AGE=600

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Security: PII encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
PII_ENCRYPTION_KEY=

# CORS (comma-separated origins for production)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_APP_NAME=PALP

# Celery
CELERY_BROKER_URL=redis://redis:6379/1

# Gunicorn
GUNICORN_WORKERS=5
GUNICORN_THREADS=2
GUNICORN_LOG_LEVEL=info

# Sentry (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.3
SENTRY_PROFILES_SAMPLE_RATE=0.1
APP_VERSION=1.0.0

# Queue alerting
QUEUE_ALERT_WARN=50
QUEUE_ALERT_CRITICAL=200

# Backup
BACKUP_RETENTION_DAYS=7

# Seed data (dev only)
SEED_PASSWORD=

# ----------------------------------------------------------------------
# AI Coach — LLM providers (Phase 4 + 5 of v3 MAXIMAL roadmap)
# ----------------------------------------------------------------------
# Default safety net when neither cloud nor local is reachable.
# Leave as ``echo`` for offline/dev; never set to a real provider here.
PALP_COACH_DEFAULT_PROVIDER=echo

# Cloud LLM provider used for normal dialogue (non-sensitive intents).
# Supported values: ``echo`` (no-op), ``openai_compat``, ``ollama``.
PALP_COACH_CLOUD_PROVIDER=openai_compat

# Local LLM provider used for sensitive intents (frustration, wellbeing,
# self-harm, …) — these NEVER leave your infra.
PALP_COACH_LOCAL_PROVIDER=ollama

# --- OpenAI-compatible cloud client ---
# Works with: OpenAI directly, key4u.shop, OpenRouter, Azure shim, vLLM,
# any other OpenAI Chat Completions compatible endpoint.
#
# Examples:
#   OpenAI direct       → BASE_URL=https://api.openai.com/v1
#                         MODEL=gpt-4o-mini  (or gpt-5)
#   key4u.shop (VN)     → BASE_URL=https://api.key4u.shop/v1
#                         MODEL=claude-sonnet-4-6  (or claude-opus-4-20250514)
#   OpenRouter          → BASE_URL=https://openrouter.ai/api/v1
#                         MODEL=anthropic/claude-sonnet-4.5
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
OPENAI_COMPAT_MODEL=gpt-4o-mini
OPENAI_COMPAT_PROVIDER_LABEL=openai_compat
OPENAI_COMPAT_TIMEOUT_SECONDS=30
OPENAI_COMPAT_MAX_OUTPUT_TOKENS=1024
OPENAI_COMPAT_TEMPERATURE=0.4

# --- Ollama (local) ---
# Install: https://ollama.com/download
# Then:    ollama pull qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_SECONDS=60
OLLAMA_TEMPERATURE=0.4
OLLAMA_NUM_PREDICT=1024

# Coach budgets / safety
PALP_COACH_DAILY_TOKEN_LIMIT=50000
PALP_COACH_MAX_INPUT_LEN=4000
PALP_COACH_JAILBREAK_COOLDOWN_HOURS=24
