{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/format-python.sh",
        "matcher": "\\.py$",
        "failClosed": false,
        "timeout": 15
      },
      {
        "command": ".cursor/hooks/ruler-apply.sh",
        "matcher": "^\\.ruler[/\\\\].*\\.(md|toml)$",
        "failClosed": false,
        "timeout": 30
      }
    ]
  }
}
