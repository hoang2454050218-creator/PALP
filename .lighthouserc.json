{
  "ci": {
    "collect": {
      "startServerCommand": "npm run start --prefix frontend",
      "startServerReadyPattern": "Ready in",
      "startServerReadyTimeout": 60000,
      "url": [
        "http://localhost:3000/login",
        "http://localhost:3000/"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "throttling": {
          "rttMs": 40,
          "throughputKbps": 10240,
          "cpuSlowdownMultiplier": 1
        }
      }
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:performance": ["error", {"minScore": 0.85}],
        "categories:accessibility": ["error", {"minScore": 0.95}],
        "categories:best-practices": ["error", {"minScore": 0.9}],
        "categories:seo": ["error", {"minScore": 0.9}],
        "uses-http2": "off",
        "csp-xss": "off",
        "is-on-https": "off",
        "redirects-http": "off",
        "uses-text-compression": ["warn", {"minScore": 0.9}],
        "render-blocking-resources": ["warn", {"minScore": 0.9}],
        "unused-javascript": ["warn", {"minScore": 0.85}],
        "unused-css-rules": ["warn", {"minScore": 0.85}],
        "max-potential-fid": ["warn", {"maxNumericValue": 200}],
        "interactive": ["warn", {"maxNumericValue": 4000}],
        "first-contentful-paint": ["warn", {"maxNumericValue": 2000}],
        "largest-contentful-paint": ["warn", {"maxNumericValue": 2500}]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
